# Path to the SQLite database (default: ./data/parkrun.db)
#PM_DB_PATH=

# Delay between requests to results-service.parkrun.com, seconds (default: 3)
#PM_REQUEST_DELAY=3

# VK notifications (optional — without a token changes are printed to stdout).
# Use a community (group) bot token; peer_id is the user or chat to notify.
#VK_TOKEN=
#VK_PEER_ID=

# Optional gate: a shell command executed before each sync. A non-zero exit
# code skips the sync (recorded as status "skipped"). Use it to coordinate
# with other parkrun tooling on the same host, e.g. skip while another
# scraper is serving a ban cooldown.
#PM_GATE_COMMAND=/path/to/parkrun_gate.sh

# Seconds between eventhistory requests in fetch-history (default: 30)
#PM_HISTORY_DELAY=30

# Collector role: command that applies stdin SQL to the canonical database
# (e.g. an ssh wrapper). Required for `push`.
#PM_PUSH_COMMAND=/path/to/push_to_server.sh
